# Dockerfile for building a Gradle project using JDK 21
FROM eclipse-temurin:25-jdk

WORKDIR /app

# Copy build tool and configuration
COPY gradlew gradle build.gradle gradle.properties ./

# Copy source files
COPY src ./src

# Ensure gradlew is executable
RUN chmod +x ./gradlew

# Build the project (disable daemon for CI/CD builds)
RUN ./gradlew clean build --no-daemon --info
